generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id            Int      @id @default(autoincrement())
  year          String
  title         String
  description   String
  tags          String
  imgSrc        String?
  liveSiteUrl   String?
  sourceCodeUrl String?
  layout        String   @default("1-col")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}